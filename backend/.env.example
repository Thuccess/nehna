# Copy to .env for local dev.
# On Render: Web Service → Environment.

# ── Server ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Browser origins allowed to call this API (comma-separated, no trailing slash).
# Must include every Vercel URL users open (production + preview if needed).
# Local:  http://localhost:3000
# Prod:   https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000

# Cross-origin auth (Vercel frontend + Render API):
# - COOKIE_SECURE=true in production (HTTPS)
# - Leave COOKIE_DOMAIN empty when frontend and API are on different hosts
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ── Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── MongoDB Atlas ───────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/adulis?retryWrites=true&w=majority

# ── Cloudflare R2 (optional — product/business images) ──────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=adulis-media
R2_PUBLIC_BASE_URL=https://media.adulis.example
