# Server
PORT=4000
NODE_ENV=development

# Comma-separated browser origins (no trailing slash). Production example:
# CORS_ORIGIN=https://nehna-two.vercel.app,http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Leave empty when frontend and API are on different hosts (Vercel + Render).
# Required for cross-site cookies: COOKIE_SECURE=true on Render (HTTPS).
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/adulis?retryWrites=true&w=majority

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=adulis-media
R2_PUBLIC_BASE_URL=https://media.adulis.example
