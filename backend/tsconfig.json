{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "jsx": "preserve",
    "types": ["node"],
    "noUncheckedIndexedAccess": false
  },
  "include": ["src/**/*"],
  "references": [{ "path": "./shared" }]
}
