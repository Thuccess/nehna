# Copy to .env.local for local dev.
# On Vercel: Project → Settings → Environment Variables (Production + Preview).

# Backend API base URL (no trailing slash)
# Local:  http://localhost:4000
# Render: https://nehna.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional — public R2 media base URL (only if you use image uploads)
NEXT_PUBLIC_R2_URL=
