{
  "name": "@adulis/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:shared": "npm run build --prefix ../backend/shared",
    "dev": "npm run build:shared && next dev --port 3000",
    "build": "npm run build:shared && next build",
    "start": "next start --port 3000",
    "lint": "next lint",
    "typecheck": "npm run build:shared && tsc -p tsconfig.json --noEmit",
    "postinstall": "npm install --prefix ../backend/shared"
  },
  "dependencies": {
    "@adulis/shared": "file:../backend/shared",
    "@tanstack/react-query": "^5.59.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.1",
    "lucide-react": "^0.453.0",
    "next": "^15.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.7.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.12.0",
    "eslint-config-next": "^15.0.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3"
  }
}
